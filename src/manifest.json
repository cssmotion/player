{
  "$schema": "https://cssmotion.dev/schema/1.0.0/manifest.json",
  "specVersion": "1.0.0",

  "identity": {
    "id": "heart-reaction",
    "name": "Heart Reaction",
    "description": "A social-media-style heart reaction. The main heart bounces in with an elastic overshoot, mini hearts float upward, and sparkle dots burst outward. Ideal for like buttons, reactions, and love moments.",
    "tags": ["heart", "reaction", "like", "love", "social", "feedback"],
    "category": "feedback",
    "generator": "Hand-crafted",
    "createdAt": "2026-03-17T10:00:00Z",
    "updatedAt": "2026-03-17T10:00:00Z",
    "revision": 1
  },

  "attribution": {
    "author": "Mushfau Saeed",
    "organization": "CSSMotion",
    "url": "https://cssmotion.dev",
    "license": "MIT"
  },

  "playback": {
    "duration": 1300,
    "iterationCount": 1,
    "direction": "normal",
    "fillMode": "forwards",
    "easing": "cubic-bezier(0.34, 1.56, 0.64, 1)",
    "autoplay": true,
    "triggers": {
      "hover": false,
      "click": true,
      "inView": true,
      "scroll": false
    },
    "intermission": 0
  },

  "dimensions": {
    "width": 400,
    "height": 400,
    "aspectRatio": "1/1",
    "scalingBehavior": "contain"
  },

  "theming": {
    "colorScheme": ["light", "dark"],
    "tokens": [
      {
        "name": "--cssm-heart-color",
        "type": "color",
        "defaultValue": "#FF3B5C",
        "description": "Main heart and some mini hearts colour",
        "group": "colors",
        "required": false
      },
      {
        "name": "--cssm-secondary-color",
        "type": "color",
        "defaultValue": "#FF8FAB",
        "description": "Secondary mini hearts colour",
        "group": "colors",
        "required": false
      },
      {
        "name": "--cssm-accent-color",
        "type": "color",
        "defaultValue": "#FFE66D",
        "description": "Sparkle dots and accent hearts colour",
        "group": "colors",
        "required": false
      }
    ]
  },

  "accessibility": {
    "reducedMotionBehavior": "static",
    "flashRisk": "none",
    "seizureRisk": false,
    "wcagLevel": "AA"
  },

  "technical": {
    "cssFeatures": ["@keyframes", "@property"],
    "scrollDriven": false,
    "viewTransition": false,
    "requiresJS": false,
    "minBrowserSupport": {
      "chrome": "111",
      "firefox": "116",
      "safari": "16.4",
      "edge": "111"
    }
  },

  "assets": {
    "svg": "animation.svg",
    "css": "animation.css"
  }
}
